rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Cek apakah user sudah login
    function isAuth() {
      return request.auth != null;
    }

    match /users/{userId} {
      // Allow unauthenticated read so the login flow can look up
      // a user's email by NIM before Firebase Auth sign-in.
      allow read: if true;
      allow write: if isAuth() && request.auth.uid == userId;
    }

    match /items/{itemId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      // Hanya pelapor yang bisa menghapus barangnya
      allow delete: if isAuth() && resource.data.reportedBy == request.auth.uid;
    }

    match /claims/{claimId} {
      allow read, write: if isAuth();
    }
    
    match /notifications/{notifId} {
      allow read, write: if isAuth();
    }

    match /comments/{commentId} {
      allow read: if isAuth();
      // Any authenticated user can create comments
      allow create: if isAuth();
      // Only the comment author can delete their own comment
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
      // No updates allowed (comments are immutable)
      allow update: if false;
    }

    match /complaints/{complaintId} {
      allow read, write: if isAuth();
    }
  }
}
